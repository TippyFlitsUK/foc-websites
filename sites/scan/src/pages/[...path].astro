---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Root } from '../Root.tsx'

// Pre-render every client-side route so IPFS gateways serve the SPA shell
// for deep links. The react-router inside <Root /> reads window.location
// and renders the right page from there.
export function getStaticPaths() {
  return [
    'calibration',
    'calibration/dataset',
    'calibration/datasets',
    'calibration/piece',
    'calibration/pieceset',
    'calibration/piecesets',
    'calibration/providers',
    'calibration/services',
    'datasets',
    'documentation',
    'gas-calculator',
    'mainnet',
    'mainnet/dataset',
    'mainnet/datasets',
    'mainnet/piece',
    'mainnet/pieceset',
    'mainnet/piecesets',
    'mainnet/providers',
    'mainnet/services',
    'piece',
    'pieceset',
    'piecesets',
  ].map((p) => ({ params: { path: p } }))
}
---
<BaseLayout>
  <Root client:only="react" />
</BaseLayout>
