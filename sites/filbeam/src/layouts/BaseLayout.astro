---
interface Props {
  title?: string
  description?: string
  /** Webflow page ID — drives IX2 animations. Required. */
  wfPage: string
}

const SITE_DESCRIPTION =
  'Filecoin Beam is the incentivized data delivery layer for Filecoin. Providers finally can get paid for serving content.'
const { title, description, wfPage } = Astro.props

const pageTitle = title ? `${title} | Filecoin Beam` : 'Filecoin Beam - Incentivized Data Delivery'
const metaDescription = description ?? SITE_DESCRIPTION
const canonPath = Astro.url.pathname === '/'
  ? '/'
  : (Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/')
const canonical = new URL(canonPath, Astro.site).href

// Staging builds noindex by default; set PROD_BUILD=1 in CI for prod deploys.
const isStaging = import.meta.env.PROD_BUILD !== '1'
---
<!DOCTYPE html>
<html data-wf-domain="filbeam.com" data-wf-page={wfPage} data-wf-site="68e964a3dedb02d0181e7cc8" lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{pageTitle}</title>
  <meta content={metaDescription} name="description"/>
  <meta content={pageTitle} property="og:title"/>
  <meta content={metaDescription} property="og:description"/>
  <meta content="/img/og-image.png" property="og:image"/>
  <meta content={pageTitle} property="twitter:title"/>
  <meta content={metaDescription} property="twitter:description"/>
  <meta property="og:type" content="website"/>
  <meta content="summary_large_image" name="twitter:card"/>
  <meta content="width=device-width, initial-scale=1" name="viewport"/>
  <link rel="canonical" href={canonical}/>
  {isStaging && <meta name="robots" content="noindex, nofollow" />}

  <link href="/css/filbeam.webflow.css" rel="stylesheet" type="text/css"/>
  <link href="https://fonts.googleapis.com" rel="preconnect"/>
  <link href="https://fonts.gstatic.com" rel="preconnect"/>

  <script is:inline src="/js/webfont.js" type="text/javascript"></script>
  <script is:inline type="text/javascript">WebFont.load({  google: {    families: ["Lato:100,100italic,300,300italic,400,400italic,700,700italic,900,900italic","Gabarito:regular,500,600,700,800,900","IBM Plex Mono:regular","Bai Jamjuree:200,200italic,300,300italic,regular,italic,500,500italic,600,600italic,700,700italic"]  }});</script>
  <script is:inline type="text/javascript">{`!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);`}</script>

  <link href="/img/favicon.png" rel="shortcut icon" type="image/x-icon"/>
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon"/>
</head>
<body class="body">
  <slot />

  <!-- Webflow runtime (jQuery + chunks) -->
  <script is:inline src="/js/jquery-3.5.1.min.js" type="text/javascript"></script>
  <script is:inline src="/js/webflow.schunk1.js" type="text/javascript"></script>
  <script is:inline src="/js/webflow.schunk2.js" type="text/javascript"></script>
  <script is:inline src="/js/webflow.main.js" type="text/javascript"></script>
</body>
</html>
