---
import BaseLayout from '../layouts/BaseLayout.astro'
import HostedOnFOC from '../components/HostedOnFOC.astro'
---

<BaseLayout title="Not Found" wfPage="68e964a3dedb02d0181e7cb0">
  <section class="section overflow-hidden" style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;">
    <div class="w-layout-blockcontainer container-two w-container">
      <h1 class="h1-heading about-hero mobile">404</h1>
      <p class="paragraph gray">Page not found.</p>
      <div class="button-container header">
        <a href="/" class="button-link-block-3 black hero-section w-inline-block">
          <div class="button-block _01 header">
            <div class="text-block-3">Back to home</div>
          </div>
        </a>
      </div>
    </div>
  </section>
  <HostedOnFOC />
</BaseLayout>
