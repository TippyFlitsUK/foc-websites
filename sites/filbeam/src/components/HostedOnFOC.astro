  .foc-badge a {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  .foc-badge span {
    font-size: 0.875rem;
    color: #8a8580;
  }
  .foc-badge img {
    height: 48px;
    width: auto;
