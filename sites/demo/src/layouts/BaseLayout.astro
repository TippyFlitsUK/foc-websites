---
interface Props {
  title?: string
  description?: string
}

const SITE_DESCRIPTION =
  'Connect a wallet and try the Filecoin Onchain Cloud Synapse Playground — onboarding, payments, and data-set operations.'
const { title, description } = Astro.props
const pageTitle = title ?? 'Filecoin Onchain Cloud Demo'
const metaDescription = description ?? SITE_DESCRIPTION
const isStaging = import.meta.env.PROD_BUILD !== '1'
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{pageTitle}</title>
    <meta content={metaDescription} name="description" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta content={pageTitle} property="og:title" />
    <meta content={metaDescription} property="og:description" />
    <meta property="og:type" content="website" />
    <meta name="keywords" content="Filecoin, Onchain Cloud, Demo" />
    <meta name="author" content="Filecoin" />
    {isStaging && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/filecoin-logo.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <div id="root"><slot /></div>
  </body>
</html>
