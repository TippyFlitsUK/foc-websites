---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Page Not Found | Filecoin Onchain Cloud" description="The page you are looking for could not be found." path="/404">
  <div class="flex min-h-[60vh] flex-col items-center justify-center text-center px-4">
    <h1 class="text-6xl font-bold text-zinc-50 mb-4">404</h1>
    <p class="text-xl text-zinc-400 mb-8">The page you are looking for could not be found.</p>
    <a href="/" class="inline-flex items-center rounded-full border border-zinc-700 px-6 py-3 text-zinc-50 hover:bg-zinc-800 transition-colors">
      Go to homepage
    </a>
  </div>
</BaseLayout>
